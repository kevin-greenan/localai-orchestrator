LOCALAI_BIND_IP=127.0.0.1
LOCALAI_QDRANT_PORT=6333

# Optional: require Basic Auth in Model Admin (http://127.0.0.1:3010)
# Leave blank to disable auth.
MODEL_ADMIN_USERNAME=
MODEL_ADMIN_PASSWORD=

# Optional: protect Qdrant API with a key.
# Leave blank to disable.
QDRANT_API_KEY=

# Optional: OpenWebUI RAG embedding model (Ollama model name/tag).
# Ensure this model exists locally (or run `localai up --sync-models`).
LOCALAI_RAG_EMBED_MODEL=nomic-embed-text

# Optional: advanced Qdrant overrides (normally auto-generated by localai).
# LOCALAI_QDRANT_DEFAULT_SEGMENT_NUMBER=2
# LOCALAI_QDRANT_MEMMAP_THRESHOLD_KB=100000
# LOCALAI_QDRANT_INDEXING_THRESHOLD_KB=50000
# LOCALAI_QDRANT_HNSW_M=24
# LOCALAI_QDRANT_HNSW_EF_CONSTRUCT=100
